# ════════════════════════════════════════════════════════════════
# data-platform - Variables de Entorno
# ════════════════════════════════════════════════════════════════
# COPIA este archivo a .env y completa los valores
# NUNCA commitees el archivo .env (ya está en .gitignore)
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# POSTGRESQL - Base de Datos
# ════════════════════════════════════════════════════════════════
POSTGRES_USER=champion07
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=data-world-cup

# ════════════════════════════════════════════════════════════════
# DATABASE URL - Usada por los microservicios (FastAPI)
# Formato: postgresql+asyncpg://user:password@host:port/dbname
# ════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://champion07:change_me_in_production@postgres:5432/data-world-cup

# ════════════════════════════════════════════════════════════════
# MINIO - Storage S3-compatible
# ════════════════════════════════════════════════════════════════
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET=core-storage

# S3 Configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=change_me_in_production